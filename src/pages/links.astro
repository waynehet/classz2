---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

let bookmarksHtml = "";
try {
  const bookmarks = await getCollection("bookmarks");
  if (bookmarks.length > 0) {
    bookmarksHtml = bookmarks[0].body;
  }
} catch (e) {
  // Content not found - will show message below
}
---

<BaseLayout title="Links - ClassZ Agile">
  <section>
    <h2 class="text-2xl font-bold text-white mb-4">Wayne'sBookmarks</h2>
    {
      bookmarksHtml ? (
        <div class="prose prose-invert max-w-none" set:html={bookmarksHtml} />
      ) : (
        <p class="text-slate-400">
          No bookmarks imported yet. Run the extraction script to add links.
        </p>
      )
    }
  </section>
</BaseLayout>
