---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = "/classz2";
---

<BaseLayout title="ClassZ Agile - Wayne Hetherington" showBackground={true}>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <section class="md:col-span-1">
      <img
        src={base + "/profile_photo.png"}
        alt="Wayne Hetherington"
        class="w-32 h-32 rounded-full mb-4 object-cover"
      />
      <h1 class="text-2xl font-bold text-white mb-2">Wayne Hetherington</h1>
      <p class="text-lg text-slate-300 mb-4">Enterprise Agile Coach</p>

      <div class="text-sm text-slate-400 mb-4">
        <span>Toronto, Ontario</span>
      </div>

      <div class="flex flex-col gap-2 text-sm">
        <a href="mailto:waynehet@gmail.com" class="text-blue-400 hover:underline">
          Email
        </a>
        <a
          href="https://www.linkedin.com/in/wayne-hetherington/"
          class="text-blue-400 hover:underline">
          LinkedIn
        </a>
      </div>
    </section>

    <section class="md:col-span-2">
      <h2 class="text-2xl font-bold text-white mb-4">Recent Posts</h2>
      <div class="space-y-4">
        <article class="border-l-4 border-blue-500 pl-4">
          <a href={base + "/blog/above-below/"} class="block">
            <h3 class="text-lg font-semibold text-slate-200 hover:text-blue-400">
              Above or Below the Line
            </h3>
            <p class="text-sm text-slate-500">less than 1 minute read</p>
          </a>
        </article>

        <article class="border-l-4 border-blue-500 pl-4">
          <a href={base + "/blog/favourite-quotes/"} class="block">
            <h3 class="text-lg font-semibold text-slate-200 hover:text-blue-400">
              My Favourite Quotes
            </h3>
            <p class="text-sm text-slate-500">3 minute read</p>
          </a>
        </article>

        <article class="border-l-4 border-blue-500 pl-4">
          <a href={base + "/blog/laws-effects-and-biases/"} class="block">
            <h3 class="text-lg font-semibold text-slate-200 hover:text-blue-400">
              Laws, Effects, and Other Cognitive Biases
            </h3>
            <p class="text-sm text-slate-500">3 minute read</p>
          </a>
        </article>
      </div>
    </section>
  </div>
</BaseLayout>