---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = '/classz2';
---

<BaseLayout title="ClassZ Agile - Wayne Hetherington">
  <section class="text-center py-8">
    <img 
      src={base + '/profile_photo.png'} 
      alt="Wayne Hetherington" 
      class="w-32 h-32 rounded-full mx-auto mb-4 object-cover"
    />
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Wayne Hetherington</h1>
    <p class="text-xl text-gray-600 mb-4">Enterprise Agile Coach</p>
    
    <div class="flex justify-center gap-4 text-sm text-gray-500 mb-8">
      <span>Toronto, Ontario</span>
      <span>&bull;</span>
      <a href="mailto:waynehet@gmail.com" class="text-blue-600 hover:underline">Email</a>
      <span>&bull;</span>
      <a href="https://www.linkedin.com/in/wayne-hetherington/" class="text-blue-600 hover:underline">LinkedIn</a>
      <span>&bull;</span>
      <a href="https://calendly.com/waynehet/30min" class="text-blue-600 hover:underline">Book me on Calendly</a>
    </div>
  </section>

  <section>
    <h2 class="text-2xl font-bold text-gray-900 mb-4">Recent Posts</h2>
    <div class="space-y-4">
      <article class="border-l-4 border-blue-500 pl-4">
        <a href={base + '/blog/above-below/'} class="block">
          <h3 class="text-lg font-semibold text-gray-800 hover:text-blue-600">Above or Below the Line</h3>
          <p class="text-sm text-gray-500">less than 1 minute read</p>
        </a>
      </article>
      
      <article class="border-l-4 border-blue-500 pl-4">
        <a href={base + '/blog/favourite_quotes/'} class="block">
          <h3 class="text-lg font-semibold text-gray-800 hover:text-blue-600">My Favourite Quotes</h3>
          <p class="text-sm text-gray-500">3 minute read</p>
        </a>
      </article>
      
      <article class="border-l-4 border-blue-500 pl-4">
        <a href={base + '/blog/laws_effects_biases/'} class="block">
          <h3 class="text-lg font-semibold text-gray-800 hover:text-blue-600">Laws, Effects, and Other Cognitive Biases</h3>
          <p class="text-sm text-gray-500">3 minute read</p>
        </a>
      </article>
    </div>
  </section>
</BaseLayout>