---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fileURLToPath } from 'node:url';

const base = '/classz2';
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const blogSlugs: Record<string, string> = {
  'blog/above-below.md': 'above-below',
  'blog/favourite-quotes.md': 'favourite-quotes',
  'blog/laws-effects-and-biases.md': 'laws-effects-and-biases',
  'blog/video-youtube.md': 'video-youtube',
  'blog/too-much-time-in-meetings.md': 'too-much-time-in-meetings',
  'blog/scrum-events.md': 'scrum-events',
  'blog/scrum-events-waste.md': 'scrum-events-waste',
  'blog/toronto-meetups.md': 'toronto-meetups',
};

function getSlug(post: { id: string }) {
  return blogSlugs[post.id] || post.id.replace(/\.md$/, '');
}
---

<BaseLayout title="Blog - ClassZ Agile">
  <h1 class="text-3xl font-bold text-white mb-6">Blog</h1>
  
  <div class="space-y-6">
    {posts.map((post) => (
      <article class="border-l-4 border-blue-500 pl-4">
        <a href={`${base}/blog/${getSlug(post)}/`} class="block">
          <h2 class="text-xl font-semibold text-slate-200 hover:text-blue-400">
            {post.data.title}
          </h2>
          <p class="text-sm text-slate-500">
            {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            {' — '}
            {post.data.description || 'Read more'}
          </p>
        </a>
      </article>
    ))}
  </div>
</BaseLayout>