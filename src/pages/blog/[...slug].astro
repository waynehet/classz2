---
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const slugs: Record<string, string> = {
    'blog/above-below.md': 'above-below',
    'blog/favourite-quotes.md': 'favourite-quotes',
    'blog/laws-effects-and-biases.md': 'laws-effects-and-biases',
    'blog/video-youtube.md': 'video-youtube',
    'blog/too-much-time-in-meetings.md': 'too-much-time-in-meetings',
    'blog/scrum-events.md': 'scrum-events',
    'blog/scrum-events-waste.md': 'scrum-events-waste',
    'blog/toronto-meetups.md': 'toronto-meetups',
  };
  return posts.map((post) => ({
    params: { slug: slugs[post.id] || post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title}>
  <article class="prose max-w-none prose-invert">
    <h1 class="text-3xl font-bold text-white mb-2">{post.data.title}</h1>
    <p class="text-sm text-slate-500 mb-8">
      {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
    </p>
    <Content />
  </article>
</BaseLayout>