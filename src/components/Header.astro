---
const base = '/classz2';

const navLinks = [
  { href: base + '/', label: 'Home' },
  { href: base + '/about/', label: 'About' },
  { href: base + '/links/', label: 'Links' },
  { href: base + '/blog/', label: 'Blog' },
];
---

<header class="bg-slate-800 shadow-md border-b border-slate-700">
  <nav class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href={base + '/'} class="flex items-center gap-3 text-xl font-bold text-white">
      <img src={base + '/assets/brain_logo.png'} alt="ClassZ" class="h-10 w-10" />
      <span>ClassZ Agile</span>
    </a>
    <ul class="flex gap-6">
      {navLinks.map(({ href, label }) => (
        <li>
          <a href={href} class="text-slate-300 hover:text-blue-400 transition-colors">
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>