---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  showBackground?: boolean;
}

const { title, description = "ClassZ Agile - by Wayne Hetherington", showBackground = false } = Astro.props;
const base = '/classz2';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={base + '/favicon-32.png'} />
    <link rel="apple-touch-icon" href={base + '/favicon-256.png'} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    {showBackground && (
      <style>
        body { background: transparent !important; }
      </style>
    )}
  </head>
  <body class="min-h-screen flex flex-col bg-slate-900 text-slate-100">
    {showBackground && (
      <img 
        src={base + '/assets/background.png'} 
        alt="Background" 
        style="position:fixed;inset:0;width:100%;height:100%;object-fit:cover;z-index:-1"
      />
    )}
    <Header />
    <main class="flex-grow max-w-4xl mx-auto px-4 py-8 w-full">
      <slot />
    </main>
    <Footer />
  </body>
</html>